generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String     @id @default(uuid())
  supabaseId    String     @unique
  email         String?
  apiKey        String     @unique @default(uuid())
  walletAddress String?
  plan          String     @default("free")
  network       String     @default("devnet")
  emailAlerts   Boolean    @default(true)
  webhookUrl           String?
  webhookSecret        String?
  stripeCustomerId     String?
  stripeSubscriptionId String?
  createdAt            DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  endpoints     Endpoint[]
  apiCalls      ApiCall[]
  transactions  Transaction[]
  agentWallets  AgentWallet[]
  proxyEndpoints ProxyEndpoint[]

  username          String?  @unique
  displayName       String?
  bio               String?
  avatarEmoji       String?  @default("👤")
  avatarColor       String?  @default("#7AF279")
  avatarImage       String?
  githubUrl         String?
  websiteUrl        String?
  twitterUrl        String?
  isPublicProfile   Boolean  @default(false)
}

model ProxyEndpoint {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])

  slug        String   @unique
  name        String
  description String?
  category    String   @default("data")

  targetUrl   String

  pricePerCall Float   @default(0.001)

  targetApiKey    String?
  targetApiHeader String?  @default("x-api-key")

  totalCalls     Int    @default(0)
  totalEarned    Float  @default(0)
  lastCallAt     DateTime?

  uptimePercent  Float  @default(100)
  avgLatencyMs   Int    @default(0)

  isActive       Boolean @default(true)
  isPublic       Boolean @default(true)
  isFeatured     Boolean @default(false)

  avatarEmoji     String?  @default("🔌")
  avatarColor     String?  @default("#7AF279")
  avatarImage     String?
  tags            String[] @default([])
  docsUrl         String?
  methods         String[] @default(["GET"])
  responseExample String?
  longDescription String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  calls       ProxyCall[]

  @@index([userId])
  @@index([slug])
  @@index([isPublic, isActive])
  @@index([category])
}

model ProxyCall {
  id              String   @id @default(uuid())
  proxyEndpointId String
  proxyEndpoint   ProxyEndpoint @relation(fields: [proxyEndpointId], references: [id])

  callerWallet    String?
  agentWalletId   String?

  amount          Float
  txHash          String?
  paymentStatus   String   @default("pending")

  latencyMs       Int?
  targetStatus    Int?

  errorCode       String?

  createdAt       DateTime @default(now())

  @@index([proxyEndpointId])
  @@index([createdAt])
  @@index([callerWallet])
}

model AgentWallet {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])

  name        String
  description String?

  privyWalletId String   @unique
  walletAddress String
  network       String  @default("mainnet")

  maxPerCall    Float?
  maxPerHour    Float?
  maxPerDay     Float?
  maxPerMonth   Float?

  allowedEndpoints String[] @default([])
  blockedEndpoints String[] @default([])

  isActive    Boolean  @default(true)

  totalCalls  Int      @default(0)
  totalSpent  Float    @default(0)
  lastCallAt  DateTime?

  agentKey    String   @unique @default(uuid())

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  calls       AgentCall[]

  @@index([userId])
  @@index([agentKey])
  @@index([walletAddress])
  @@index([privyWalletId])
}

model AgentCall {
  id            String      @id @default(uuid())
  agentWalletId String
  agentWallet   AgentWallet @relation(fields: [agentWalletId], references: [id])

  endpoint    String
  amount      Float
  status      String
  txHash      String?
  blockReason String?
  latencyMs   Int?

  createdAt   DateTime @default(now())

  @@index([agentWalletId])
  @@index([createdAt])
  @@index([agentWalletId, createdAt])
}

model Endpoint {
  id          String    @id @default(uuid())
  path        String
  priceUsdc   Float
  active      Boolean   @default(true)
  description String?
  userId      String?
  user        User?     @relation(fields: [userId], references: [id])
  calls        ApiCall[]
  transactions Transaction[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @default(now()) @updatedAt

  @@unique([path, userId])
}

model Transaction {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  endpointId      String?
  endpoint        Endpoint? @relation(fields: [endpointId], references: [id])
  txHashProvider  String   @unique
  txHashPlatform  String?  @unique
  totalAmount     Float
  providerAmount  Float
  platformFee     Float
  status          String   @default("pending")
  network         String   @default("devnet")
  payerWallet     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  splits          Split[]
}

model Split {
  id            String      @id @default(uuid())
  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id])
  recipient     String
  wallet        String
  amount        Float
  txHash        String
  status        String      @default("pending")
  confirmedAt   DateTime?
  createdAt     DateTime    @default(now())
}

model IdempotencyKey {
  id        String   @id @default(uuid())
  key       String   @unique
  type      String
  usedAt    DateTime @default(now())
  expiresAt DateTime
  metadata  String?
}

model RevenueLog {
  id          String   @id @default(uuid())
  source      String
  amount      Float
  currency    String   @default("USDC")
  txHash      String?
  userId      String?
  description String?
  createdAt   DateTime @default(now())
}

model UsageMetric {
  id           String   @id @default(uuid())
  userId       String
  endpointId   String
  requestId    String?
  metricType   String
  metricValue  Float
  unit         String
  pricePerUnit Float
  totalPrice   Float
  settledAt    DateTime?
  createdAt    DateTime @default(now())
}

model RateLimitEntry {
  id         String   @id @default(uuid())
  identifier String
  type       String
  window     String
  count      Int      @default(0)
  resetAt    DateTime
  createdAt  DateTime @default(now())

  @@unique([identifier, type, window])
}

model ApiCall {
  id          String    @id @default(uuid())
  endpointId  String?
  endpoint    Endpoint? @relation(fields: [endpointId], references: [id])
  userId      String?
  user        User?     @relation(fields: [userId], references: [id])
  txHash      String    @unique
  amountUsdc  Float
  payerWallet String?
  status      String    @default("confirmed")
  latencyMs   Int?
  failReason  String?
  createdAt   DateTime  @default(now())
}
